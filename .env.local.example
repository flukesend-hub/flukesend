# Flukesend environment template.
# Copy this file to .env.local and fill in the values. .env.local is gitignored
# and must never be committed. Find these in your Supabase dashboard under
# Settings > API.

# Project URL and the public anon key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Bypasses row level security. SERVER ONLY.
# Never add a NEXT_PUBLIC prefix to this and never import it into client code.
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email. The nightly review job sends through this. Leave
# blank until a sending domain is verified; the job runs and reports who is due
# but sends nothing while this is empty.
RESEND_API_KEY=
# The verified from address for review emails, e.g. "Flukesend <reviews@flukesend.com>".
REVIEW_FROM_EMAIL=

# Shared secret for the Vercel cron endpoint. Set the same value in the Vercel
# project so the scheduled request is authorized. SERVER ONLY.
CRON_SECRET=
